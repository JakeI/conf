#!/usr/bin/env -S uv run --script

import json
from urllib.request import urlopen
def build_rows(d):
    return [
        ("Temperature",   f'{d["temperature"]["value"]}{d["temperature"]["unit"]}'),
        ("Dew Point",     f'{d["dewpoint"]["value"]}{d["dewpoint"]["unit"]}'),
        ("Humidity",      f'{d["humidity"]["value"]}{d["humidity"]["unit"]}'),
        ("Pressure",      f'{d["pressure"]["value"]}{d["pressure"]["unit"]}'),
        ("Ground Press.", f'{d["ground-pressure"]["value"]}{d["ground-pressure"]["unit"]}'),
        ("Wind",          f'{d["wind_direction"]["string"]} ({d["wind_direction"]["value"]:.0f}°) '
                          f'{d["wind_speed"]["value"]}{d["wind_speed"]["unit"]}'),
        ("UV Index",      str(d["uv"]["value"])),
        ("Radiation",     f'{d["global_radiation"]["value"]}{d["global_radiation"]["unit"]}'),
        ("Cloud Base",    f'{d["cbh_cur"]["string"]}{d["cbh_cur"]["unit"]}'),
        ("Rain (1h)",     f'{d["precip"]["precip_last_hour"]["value"]}'
                          f'{d["precip"]["precip_last_hour"]["unit"]}'),
        ("Rain Rate",     f'{d["precip"]["precip_rate"]["value"]}'
                          f'{d["precip"]["precip_rate"]["unit"]}'),
        ("Rain Type",     d["precip"]["precip_type"]["value"]),
        ("Ozone",         f'{d["ozone"]["value"]}{d["ozone"]["unit"]}'),
    ]


def render_table(rows, title):
    name_w = max(len(name) for name, _ in rows)
    val_w = max(len(value) for _, value in rows)

    print(f"{title}")
    print(f"{'─' * (name_w + 1)}┬{'─' * (val_w + 1)}")

    for name, value in rows:
        print(f"{name:<{name_w}} │ {value}")



d = json.load(urlopen(
    "https://atmos.meteo.uni-koeln.de/~citystation/webDashboard/data.json",
    timeout=5
))

render_table(build_rows(d), d["datetime"])
